{
  "name": "arbiter-language",
  "displayName": "Arbiter Language",
  "description": "Syntax highlighting, comments, brackets, and snippets for Arbiter .arb files.",
  "version": "0.4.2",
  "publisher": "odvcencio",
  "license": "MIT",
  "main": "./extension.js",
  "engines": {
    "vscode": "^1.88.0"
  },
  "activationEvents": [
    "onLanguage:arbiter",
    "onCommand:arbiter.checkCurrentFile"
  ],
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "arbiter",
    "dsl",
    "rules",
    "feature-flags",
    "expert-system"
  ],
  "contributes": {
    "languages": [
      {
        "id": "arbiter",
        "aliases": [
          "Arbiter",
          "arbiter"
        ],
        "extensions": [
          ".arb"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "arbiter",
        "scopeName": "source.arbiter",
        "path": "./syntaxes/arb.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "arbiter",
        "path": "./snippets/arbiter.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "arbiter.checkCurrentFile",
        "title": "Arbiter: Check Current File"
      }
    ],
    "configuration": {
      "title": "Arbiter",
      "properties": {
        "arbiter.cliPath": {
          "type": "string",
          "default": "arbiter",
          "description": "Path to the Arbiter CLI used for diagnostics."
        },
        "arbiter.runCheckOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run `arbiter check` automatically when an .arb file is opened or saved."
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/odvcencio/arbiter"
  }
}
